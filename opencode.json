{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "agent": {
    "plan": {
      "description": "Read-only planning mode: read all files, run tests, edit markdown only",
      "mode": "primary",
      "permission": {
        "read": {
          "*": "allow",
          ".env*": "deny",
          "*credentials*": "deny",
          "*secret*": "deny",
          "*token*": "deny",
          "*.key": "deny",
          "*.pem": "deny",
          "*.p12": "deny",
          "*.pfx": "deny"
        },
        "edit": {
          "*.md": "allow",
          "*": "deny"
        },
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": {
          "make test*": "allow",
          "make test": "allow",
          "make test-unit": "allow",
          "make test-tui": "allow",
          "make test-integration": "allow",
          "make test-all": "allow",
          "make test-race": "allow",
          "make test-coverage": "allow",
          "make test-mocks": "allow",
          "make vet": "allow",
          "make bench": "allow",
          "git status": "allow",
          "git diff": "allow",
          "git log": "allow",
          "git ls-files": "allow",
          "*": "deny"
        },
        "external_directory": {
          "*": "deny"
        },
        "task": "allow",
        "todowrite": "allow",
        "question": "allow"
      }
    },
    "build": {
      "description": "Full build mode: read/write all files, run make, git add",
      "mode": "primary",
      "permission": {
        "read": {
          "*": "allow",
          ".env*": "deny",
          "*credentials*": "deny",
          "*secret*": "deny",
          "*token*": "deny",
          "*.key": "deny",
          "*.pem": "deny",
          "*.p12": "deny",
          "*.pfx": "deny"
        },
        "edit": {
          "*": "allow",
          ".env*": "deny",
          "*credentials*": "deny",
          "*secret*": "deny",
          "*token*": "deny",
          "*.key": "deny",
          "*.pem": "deny",
          "*.p12": "deny",
          "*.pfx": "deny"
        },
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": {
          "make *": "allow",
          "git add *": "allow",
          "git status": "allow",
          "git diff": "allow",
          "git log": "allow",
          "git ls-files": "allow",
          "git checkout *": "allow",
          "git stash*": "allow",
          "*": "ask"
        },
        "external_directory": {
          "*": "deny"
        },
        "task": "allow",
        "todowrite": "allow",
        "question": "allow"
      }
    }
  }
}
