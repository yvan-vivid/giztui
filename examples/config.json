{
  "accounts": [
    {
      "id": "personal",
      "credentials": "google-oauth",
      "display_name": "Personal Gmail",
      "active": true
    }
  ],
  "llm": {
    "enabled": true,
    "provider": "ollama",
    "model": "llama3.2:latest",
    "endpoint": "http://localhost:11434/api/generate",
    "api_key": "",
    "timeout": "20s",
    "stream_enabled": true,
    "stream_chunk_ms": 60,
    "cache_enabled": true,
    "cache_path": "",
    "summarize_template": "templates/ai/summarize.md",
    "reply_template": "templates/ai/reply.md",
    "label_template": "templates/ai/label.md",
    "touch_up_template": "templates/ai/touch_up.md"
  },
  "slack": {
    "enabled": false,
    "channels": [
      {
        "id": "general",
        "name": "General",
        "webhook_url": "https://hooks.slack.com/services/YOUR/WEBHOOK/URL",
        "default": true,
        "description": "General team updates"
      },
      {
        "id": "urgent",
        "name": "Urgent Alerts",
        "webhook_url": "https://hooks.slack.com/services/YOUR/URGENT/WEBHOOK",
        "default": false,
        "description": "For urgent notifications only"
      }
    ],
    "defaults": {
      "format_style": "summary"
    },
    "summary_template": "templates/slack/summary.md",
    "_format_styles_info": {
      "summary": "AI-generated summary using the summary_prompt template",
      "compact": "Headers + 200 char preview (From, Subject, body preview)",
      "full": "Complete email with TUI-processed content (includes LLM touch-up if enabled)",
      "raw": "Minimal processing, basic HTML-to-text conversion only"
    }
  },
  "layout": {
    "auto_resize": true,
    "wide_breakpoint": {
      "width": 120,
      "height": 30
    },
    "medium_breakpoint": {
      "width": 80,
      "height": 25
    },
    "narrow_breakpoint": {
      "width": 60,
      "height": 20
    },
    "default_layout": "auto",
    "show_borders": true,
    "show_titles": true,
    "compact_mode": false,
    "max_recipient_lines": 3,
    "_max_recipient_lines_info": "Controls truncation of To/Cc fields when recipient lists are very long. Prevents important fields (Labels, Date) from being cut off. Valid range: 1-10, default: 3"
  },
  "theme": {
    "current": "gmail-dark",
    "custom_dir": ""
  },
  "keys": {
    "_comment": "Customize keyboard shortcuts to match your preferences. All shortcuts are configurable!",
    "_note": "See docs/CONFIGURATION.md for detailed configuration guidance and conflict resolution",
    "_validation": "Keyboard shortcut validation - warns when overriding shortcuts without alternatives",
    "validate_shortcuts": true,
    "_validation_help": "Set to false if you prefer command-line interfaces (:search, :archive, etc.) over shortcuts",
    "_vim_timeouts": "VIM sequence timeouts in milliseconds",
    "vim_navigation_timeout_ms": 1000,
    "vim_range_timeout_ms": 2000,
    "_core_operations": "Core email operations",
    "summarize": "y",
    "force_regenerate_summary": "j",
    "generate_reply": "g",
    "suggest_label": "o",
    "reply": "r",
    "reply_all": "E",
    "forward": "f",
    "compose": "c",
    "load_more": "Y",
    "refresh": "R",
    "search": "s",
    "unread": "u",
    "archived": "B",
    "search_from": "F",
    "search_to": "T",
    "search_subject": "S",
    "toggle_read": "t",
    "undo": "U",
    "trash": "d",
    "archive": "a",
    "move": "m",
    "prompt": "p",
    "drafts": "D",
    "attachments": "A",
    "manage_labels": "l",
    "quit": "q",

    "_additional_shortcuts": "Additional configurable shortcuts",
    "obsidian": "Shift+O",
    "open_gmail": "O",
    "slack": "K",
    "markdown": "M",
    "save_message": "w",
    "save_raw": "W",
    "rsvp": "V",
    "link_picker": "L",
    "theme_picker": "H",
    "bulk_mode": "v",
    "bulk_select": "space",
    "command_mode": ":",
    "help": "?",
    "toggle_headers": "h",
    "accounts": "ctrl+a",

    "_content_navigation": "Enhanced content navigation shortcuts",
    "content_search": "/",
    "search_next": "n",
    "search_prev": "N",
    "fast_up": "ctrl+k",
    "fast_down": "ctrl+j",
    "word_left": "ctrl+h",
    "word_right": "ctrl+l",
    "goto_top": "gg",
    "goto_bottom": "G",

    "_threading_navigation": "Message threading shortcuts",
    "toggle_threading": "T",
    "expand_all_threads": "E",
    "collapse_all_threads": "C",
    "thread_summary": "shift+t",
    "next_thread": "ctrl+n",
    "prev_thread": "ctrl+p",

    "_examples": "Example customizations (uncomment and modify as needed):",
    "_vim_style": "Vim-style shortcuts:",
    "_example1": "\"reply\": \"r\", \"compose\": \"i\", \"search\": \"/\", \"quit\": \":q\"",
    "_emacs_style": "Emacs-style shortcuts:",
    "_example2": "\"compose\": \"C-x\", \"search\": \"C-s\", \"quit\": \"C-x C-c\"",
    "_custom_workflow": "Custom workflow shortcuts:",
    "_example3": "\"summarize\": \"1\", \"generate_reply\": \"2\", \"suggest_label\": \"3\""
  },
  "threading": {
    "_comment": "Message threading configuration - group related messages in conversations",
    "enabled": true,
    "default_view": "flat",
    "auto_expand_unread": false,
    "show_thread_count": true
  },
  "obsidian": {
    "enabled": true,
    "vault_path": "~/Documents/Obsidian/MyVault",
    "ingest_folder": "00-Inbox",
    "filename_format": "{{date}}_{{subject_slug}}_{{from_domain}}",
    "history_enabled": true,
    "prevent_duplicates": true,
    "max_file_size": 1048576,
    "include_attachments": true,
    "template_file": "templates/obsidian/email.md",
    "repopack_template_file": "templates/obsidian/repopack.md"
  },
  "attachments": {
    "download_path": "~/Downloads/gmail-attachments",
    "auto_open": true,
    "max_download_size": 52428800
  },
  "performance": {
    "_comment": "Performance optimization settings - background preloading improves navigation speed",
    "preloading": {
      "_comment": "Background message preloading for instant navigation",
      "enabled": true,
      "next_page": {
        "_comment": "Preload next page when scrolling reaches threshold",
        "enabled": true,
        "threshold": 0.7,
        "max_pages": 2
      },
      "adjacent_messages": {
        "_comment": "Preload messages around current selection for smooth navigation",
        "enabled": true,
        "count": 3
      },
      "limits": {
        "_comment": "Resource limits to prevent excessive memory/API usage",
        "background_workers": 3,
        "cache_size_mb": 50,
        "api_quota_reserve_percent": 20
      }
    }
  },
  "display": {
    "_comment": "UI display preferences",
    "show_message_numbers": false
  }
}
